# VocabSync Firebase / Supabase Configuration
# Rename this file to .env.local and fill in your keys.

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# For Automated Data Fetching (Giphy/Pexels API)
# We will use this in the automation script
GIPHY_API_KEY=your_giphy_api_key_here
